import wixData from 'wix-data';

(async () => {
  try {
    const results = await wixData.query("PortfolioProjects").find();

    const projects = results.items.map((item, index) => ({
      id: item._id || `project-${index + 1}`,
      title: item.title || "Untitled Project",
      category: item.category || "Uncategorized",
      description: item.description || "",
      coverImage: item.coverImage,
      images: item.images || [],
      order: item.order || index + 1,
      visible: item.visible !== false
    }));

    // Send data to your widget
    window.postMessage({
      type: "WIX_PORTFOLIO_DATA",
      projects
    }, "*");

  } catch (err) {
    console.error("CMS BRIDGE ERROR:", err);
  }
})();